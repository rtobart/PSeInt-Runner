{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PSeInt",
  "scopeName": "source.psc",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.psc",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.psc",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.psc",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.psc",
          "match": "(?i)\\b(Proceso|FinProceso|Algoritmo|FinAlgoritmo|Si|Entonces|Sino|SinoSi|FinSi|Para|Hasta|Con|Paso|FinPara|Mientras|FinMientras|Repetir|HastaQue)\\b"
        },
        {
          "name": "keyword.other.psc",
          "match": "(?i)\\b(Escribir|Leer|Definir|Como)\\b"
        },
        {
          "name": "constant.language.boolean.psc",
          "match": "(?i)\\b(Verdadero|Falso)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.psc",
          "match": "(?i)\\b(Entero|Real|Cadena|Logico|Caracter)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.psc",
          "match": "(?i)\\b(Y|O|No)\\b"
        },
        {
          "name": "keyword.operator.assignment.psc",
          "match": "<-"
        },
        {
          "name": "keyword.operator.comparison.psc",
          "match": "(<=|>=|<>|<|>|=)"
        },
        {
          "name": "keyword.operator.arithmetic.psc",
          "match": "[+\\-*/%^]"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.psc",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.psc",
          "match": "\\b[a-zA-ZáéíóúÁÉÍÓÚñÑ_][a-zA-ZáéíóúÁÉÍÓÚñÑ_0-9]*\\b"
        }
      ]
    }
  }
}
